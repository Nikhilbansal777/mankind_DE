### ---- Project Outputs (generated; keep source small) ----
# Generic generated outputs
transformed_outputs/
Data_cleaning/MKM_Glue_tranformations/transformed_outputs/

# Validation & cleaning outputs (adjust to your actual paths)
MKM_Data_Validation_and_cleaning/cleaned_outputs/
MKM_Data_Validation_and_cleaning/reports/
MKM_Data_Validation_and_cleaning/tmp/

# Profiling reports can get huge; default ignore
MKM_Data_Profiling/profiling_reports/

### ---- Data dumps (default ignore) ----
*.sqlite
*.csv
*.json

# ---- Keep config & schema under version control (override ignores) ----
# Keep config & schema JSON/YAML in src/config and similar
!src/config/**
!**/config/*.json
!**/config/*.yaml
!**/config/*.yml

# If you want to version a small curated subset of profiling/validation, un-comment the below
# !MKM_Data_Profiling/profiling_reports/keep/**
# !MKM_Data_Validation_and_cleaning/reports/keep/**

### ---- Archives ----
*.zip
